{
  "name": "qr-ordering-system-2",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "predev": "pnpm -C packages/shared build",
    "dev": "concurrently -n api,web -c blue,green \"pnpm -C apps/api dev\" \"pnpm -C apps/web dev\"",
    "api:dev": "pnpm -C packages/shared build && pnpm -C apps/api dev",
    "web:dev": "pnpm -C packages/shared build && pnpm -C apps/web dev",
    "printer:dev": "pnpm -C apps/printer dev",
    "printer:once": "pnpm -C apps/printer start -- --once",
    "db:generate": "pnpm -C apps/api db:generate",
    "db:migrate": "pnpm -C apps/api db:migrate",
    "db:deploy": "pnpm -C apps/api db:deploy",
    "db:seed": "pnpm -C apps/api db:seed",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "smoke:p0": "node scripts/smoke-p0.mjs",
    "smoke:p1": "node scripts/smoke-p1.mjs",
    "smoke:p1-members": "node scripts/smoke-p1-members.mjs",
    "smoke:p1-inventory": "node scripts/smoke-p1-inventory.mjs",
    "smoke:p1-recipes": "node scripts/smoke-p1-recipes.mjs",
    "smoke:p1-feedback": "node scripts/smoke-p1-feedback.mjs",
    "smoke:p2-multistore": "node scripts/smoke-p2-multistore.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "prettier": "^3.7.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
